# Frontend GraphQL endpoint (Encore backend)
VITE_GRAPHQL_URL=http://127.0.0.1:4000/graphql

# Server-side rendering backend origin.
# Required only when VITE_GRAPHQL_URL is relative (example: /graphql).
SSR_API_ORIGIN=http://127.0.0.1:4000

# Wealth GraphQL endpoint (optional; defaults to VITE_GRAPHQL_URL with /graphql -> /wealth/graphql)
VITE_WEALTH_GRAPHQL_URL=http://127.0.0.1:4000/wealth/graphql

# Inventory GraphQL endpoint (optional; defaults to VITE_GRAPHQL_URL with /graphql -> /inventory/graphql)
VITE_INVENTORY_GRAPHQL_URL=http://127.0.0.1:4000/inventory/graphql

# Accounting country preset for amount formatting and currency labels (IN, US, GB, AE, SG, AU, CA)
VITE_ACCOUNTING_COUNTRY_CODE=IN
