        <Column header="" body={errorBody} style={{ minWidth: 260 }} />
      </DataTable>

      {/* Footer */}
      <div className="flex flex-wrap justify-content-between align-items-center mt-3 p-2 border-1 surface-border border-round">
        <div className="flex flex-wrap gap-4">
