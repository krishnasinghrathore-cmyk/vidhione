      { id: "2", name: "Milk 1L (Batch+Expiry)", sku: "DAI-010", barcode: "8900002", hsn: "04012000", gstRate: 5, unit: "pcs", requiresBatch: true, requiresExpiry: true, prices: { retail: 60, wholesale: 57 }, stock: 45 },
      { id: "3", name: "Phone (Serial)", sku: "ELC-555", barcode: "8900009", hsn: "85171290", gstRate: 18, unit: "pcs", requiresSerial: true, prices: { retail: 12999, wholesale: 12500 }, stock: 8 },
      { id: "4", name: "Rice (Loose)", sku: "GRC-200", barcode: "8900003", hsn: "10063020", gstRate: 5, unit: "kg", prices: { retail: 55, wholesale: 52 }, stock: 320 },
    ],
