  // Validation
  const validateBeforeSave = () => {
    let ok = true;

    setRows((prev) =>
      prev.map((r) => {
        if (!r.itemId) return r;

        const msgs: string[] = [];
        if (!r.hsn || !r.hsn.trim()) msgs.push("Missing HSN/SAC");
        if (!r.qty || r.qty <= 0) msgs.push("Qty must be > 0");
        if (r.rate == null || r.rate < 0) msgs.push("Rate invalid");
        if (r.gstRate == null) msgs.push("GST% missing");
        if (r.discMode === "PERCENT" && (r.discValue < 0 || r.discValue > 100)) msgs.push("Discount % must be 0..100");

        const shouldValidateInventory = inventoryMode || r.requiresBatch || r.requiresExpiry || r.requiresSerial;

        if (shouldValidateInventory) {
          if (r.requiresBatch && !(r.batchNo ?? "").trim()) msgs.push("Batch No required");
          if (r.requiresExpiry && !r.expiry) msgs.push("Expiry required");
          if (r.requiresSerial) {
            const count = (r.serials ?? []).length;
            if (count === 0) msgs.push("Serials required");
            if (count !== r.qty) msgs.push(`Serial count (${count}) must match Qty (${r.qty})`);
          }
        }

        if (msgs.length) {
          ok = false;
          return { ...r, hasError: true, errorMsg: msgs.join(" • ") };
        }
        return { ...r, hasError: false, errorMsg: "" };
      })
    );

    if (!ok) {
      toast.current?.show({ severity: "error", summary: "Fix errors", detail: "Some rows are invalid (HSN/GST/Inventory).", life: 3500 });
