            <div className="flex justify-content-between"><span className="text-600">IGST</span><b>₹{taxPanelData.igst.toFixed(2)}</b></div>
            <hr />
            <div className="flex justify-content-between"><span className="text-600">Line Total</span><b>₹{taxPanelData.amount.toFixed(2)}</b></div>
          </div>
        )}
      </OverlayPanel>

      {/* Quick help */}
      <div className="mt-2 text-600">
        Shortcuts: <b>F1</b> item search • <b>F4</b> save • <b>F8</b> inventory strict • <b>Del</b> remove selected row • <b>Ctrl+D</b> duplicate selected row • <b>Enter</b> moves to next cell
      </div>
    </div>
  );
}
