    }

    const lots = lotsByItemId.get(r.itemId) ?? [];
    const lotOptions = lots.map((l) => ({
      label: `${l.batchNo} • Exp: ${String(l.expiry.getMonth() + 1).padStart(2, "0")}/${String(l.expiry.getFullYear()).slice(-2)} • Avl: ${l.availableQty}`,
      value: l.batchNo,
