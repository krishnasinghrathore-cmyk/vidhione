                    {priceList === "retail" ? "Retail" : "Wholesale"}: ₹{it.prices[priceList].toFixed(2)}
                    {(it.requiresBatch || it.requiresExpiry || it.requiresSerial) && " • Track: "}
                    {it.requiresBatch ? "Batch " : ""}
                    {it.requiresExpiry ? "Expiry " : ""}
                    {it.requiresSerial ? "Serial" : ""}
