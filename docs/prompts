  const [query, setQuery] = useState("");
  const [suggestions, setSuggestions] = useState<ItemMaster[]>([]);
  const onSearch = (e: AutoCompleteCompleteEvent) => {
    const q = (e.query ?? "").toLowerCase();
    const res = allItems.filter((x) => [x.name, x.sku, x.barcode, x.hsn].filter(Boolean).some((v) => v!.toLowerCase().includes(q)));
    setSuggestions(res.slice(0, 25));
  };

  // Rows
  const [rows, setRows] = useState<Line[]>(() => [makeBlankLine()]);

  const anyInventoryFieldsNeeded = useMemo(() => {
    const lines = rows.filter((r) => r.itemId);
    return {
      batch: lines.some((r) => !!r.requiresBatch),
      expiry: lines.some((r) => !!r.requiresExpiry),
      serial: lines.some((r) => !!r.requiresSerial),
    };
  }, [rows]);

  const showExpander = anyInventoryFieldsNeeded.batch || anyInventoryFieldsNeeded.expiry || anyInventoryFieldsNeeded.serial;

  const upsertBlankRowIfNeeded = (list: Line[]) => {
    if (!list.length) return [makeBlankLine()];
    const last = list[list.length - 1];
    if (!!last.itemId) return [...list, makeBlankLine()];
    return list;
  };

  const applyCalc = (line: Line): Line => {
    const c = calcLine({
      qty: line.qty,
      rate: line.rate,
      discMode: line.discMode,
      discValue: line.discValue,
      gstRate: line.gstRate,
      isIntraState,
      taxInclusiveRate,
    });
    return { ...line, ...c };
  };

  const addItemToGrid = (it: ItemMaster) => {
    setRows((prev) => {
      // If already exists and not serial-tracked, increment qty
      const idx = prev.findIndex((r) => r.itemId === it.id);
      if (idx >= 0 && !it.requiresSerial) {
        const clone = [...prev];
        const updated = applyCalc({ ...clone[idx], qty: clone[idx].qty + 1 });
        clone[idx] = updated;
        return upsertBlankRowIfNeeded(clone);
      }

      const blankIdx = prev.findIndex((r) => !r.itemId);
      const targetIdx = blankIdx >= 0 ? blankIdx : prev.length;

      const defaultRate = it.prices[priceList];
      const lots = lotsByItemId.get(it.id) ?? [];
      const bestLot = lots.length ? lots[0] : null; // FEFO default

      const line: Line = applyCalc({
        key: blankIdx >= 0 ? prev[blankIdx].key : uid(),
        itemId: it.id,
        itemName: it.name,
        hsn: it.hsn,
        unit: it.unit,
        qty: 1,
        rate: defaultRate,
        discMode: "PERCENT",
        discValue: 0,
        gstRate: it.gstRate,
        batchNo: bestLot?.batchNo ?? "",
        expiry: bestLot?.expiry ?? null,
        serials: [],
        requiresBatch: !!it.requiresBatch,
        requiresExpiry: !!it.requiresExpiry,
        requiresSerial: !!it.requiresSerial,
        taxable: 0,
        cgst: 0,
        sgst: 0,
        igst: 0,
        amount: 0,
      });

      const clone = [...prev];
      clone[targetIdx] = line;
      return upsertBlankRowIfNeeded(clone);
    });

    setQuery("");
    searchRef.current?.focus();
  };

  // Price list change: reprice existing lines (optional)
  useEffect(() => {
    setRows((prev) =>
      prev.map((r) => {
        if (!r.itemId) return r;
        const it = allItems.find((x) => x.id === r.itemId);
        if (!it) return r;
        return applyCalc({ ...r, rate: it.prices[priceList] });
      })
    );
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [priceList]);

  const removeRow = (key: string) => {
    setRows((prev) => upsertBlankRowIfNeeded(prev.filter((r) => r.key !== key)));
    setSelected((cur) => (cur?.key === key ? null : cur));
  };

  const duplicateRow = (key: string) => {
    setRows((prev) => {
      const idx = prev.findIndex((r) => r.key === key);
      if (idx < 0) return prev;
      const src = prev[idx];
      if (!src.itemId) return prev;

      // duplicate (new key). keep inventory fields too.
      const copy: Line = applyCalc({
        ...src,
        key: uid(),
        // serials are usually unique per item; duplicate without serials (safer)
        serials: src.requiresSerial ? [] : (src.serials ?? []),
      });

      const clone = [...prev];
      // insert after current row
      clone.splice(idx + 1, 0, copy);
      return upsertBlankRowIfNeeded(clone);
    });
  };

  const updateRowField = (key: string, patch: Partial<Line>) => {
    setRows((prev) =>
      prev.map((r) => {
        if (r.key !== key) return r;
        const updated = applyCalc({ ...r, ...patch });
        return { ...updated, hasError: false, errorMsg: "" };
      })
    );
  };

  // Cell edit complete
  const onCellEditComplete = (e: DataTableCellEditCompleteEvent) => {
    const { rowData, newValue, field } = e;
    setRows((prev) =>
      prev.map((r) => {
        if (r.key !== (rowData as Line).key) return r;

        let updated: Line = { ...r, [field as keyof Line]: newValue } as Line;

        // clamp % discount
        if (field === "discMode") {
          if (newValue === "PERCENT") updated.discValue = Math.min(100, Math.max(0, updated.discValue || 0));
        }
        if (field === "discValue" && updated.discMode === "PERCENT") {
          updated.discValue = Math.min(100, Math.max(0, Number(updated.discValue ?? 0)));
        }

        // If serial-tracked and qty edited, keep it but validation will enforce match.
        updated = applyCalc(updated);
        return { ...updated, hasError: false, errorMsg: "" };
      })
    );
  };

  // Editors with Enter-to-next-cell navigation
  const numberEditor =
    (field: keyof Line, min = 0, max?: number) =>
    (options: ColumnEditorOptions) => (
      <InputNumber
        value={(options.value as number) ?? 0}
        min={min}
        max={max}
        useGrouping={false}
        onValueChange={(e: InputNumberValueChangeEvent) => options.editorCallback(Number(e.value ?? 0))}
        onKeyDown={(e) => {
          if (isEnter(e)) {
            e.preventDefault();
            // commit current input value by blurring
            (e.currentTarget as unknown as HTMLElement).blur?.();
            focusNextEditableCell(e.currentTarget as unknown as HTMLElement);
          }
        }}
      />
    );

  const discModeEditor = (options: ColumnEditorOptions) => (
    <SelectButton
      value={options.value as DiscMode}
      options={[
        { label: "%", value: "PERCENT" },
        { label: "₹", value: "AMOUNT" },
      ]}
      onChange={(e) => options.editorCallback(e.value)}
      onKeyDown={(e) => {
        if (isEnter(e)) {
          e.preventDefault();
          focusNextEditableCell(e.currentTarget as unknown as HTMLElement);
        }
      }}
    />
  );

