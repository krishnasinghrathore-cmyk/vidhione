type InvoiceMode = "B2C" | "B2B";
type PriceList = "retail" | "wholesale";
type DiscMode = "PERCENT" | "AMOUNT";

type ItemMaster = {
  id: string;
  name: string;
  sku?: string;
  barcode?: string;
  hsn: string;
  gstRate: number; // %
  unit: string;

  requiresBatch?: boolean;
  requiresExpiry?: boolean;
  requiresSerial?: boolean;

  prices: {
    retail: number;
    wholesale: number;
  };

  stock?: number;
};

type Line = {
  key: string;

  itemId?: string;
  itemName?: string;

  hsn?: string;
  unit?: string;

  qty: number;
  rate: number;

  discMode: DiscMode;
  discValue: number; // % or ₹

  gstRate: number;

  // inventory fields
  batchNo?: string;
  expiry?: Date | null; // stored as Date
  serials?: string; // comma/space separated; you can store as array later

  requiresBatch?: boolean;
  requiresExpiry?: boolean;
  requiresSerial?: boolean;

  taxable: number;
  cgst: number;
  sgst: number;
  igst: number;
  amount: number;

  hasError?: boolean;
  errorMsg?: string;
};

function uid() {
  return Math.random().toString(16).slice(2) + Date.now().toString(16);
}

const round2 = (n: number) => Math.round(n * 100) / 100;

function parseSerials(text?: string) {
  return (text ?? "")
    .split(/[\s,]+/)
    .map((s) => s.trim())
    .filter(Boolean);
}

function discAmount(lineBase: number, discMode: DiscMode, discValue: number) {
  if (discMode === "PERCENT") {
    const pct = Math.min(100, Math.max(0, discValue || 0));
    return (lineBase * pct) / 100;
  }
  return Math.min(lineBase, Math.max(0, discValue || 0));
}

function calcLine(opts: {
  qty: number;
  rate: number;
  discMode: DiscMode;
  discValue: number;
  gstRate: number;
  isIntraState: boolean;
  taxInclusiveRate: boolean;
}) {
  const { qty, rate, discMode, discValue, gstRate, isIntraState, taxInclusiveRate } = opts;

  const lineBase = Math.max(0, qty) * Math.max(0, rate);
  const discAmt = discAmount(lineBase, discMode, discValue);
  const baseAfterDisc = Math.max(0, lineBase - discAmt);

  if (gstRate <= 0) {
    return {
      taxable: round2(baseAfterDisc),
      cgst: 0,
      sgst: 0,
      igst: 0,
      amount: round2(baseAfterDisc),
    };
  }

  if (!taxInclusiveRate) {
    const tax = (baseAfterDisc * gstRate) / 100;
    const cgst = isIntraState ? tax / 2 : 0;
    const sgst = isIntraState ? tax / 2 : 0;
    const igst = isIntraState ? 0 : tax;
    return {
      taxable: round2(baseAfterDisc),
      cgst: round2(cgst),
      sgst: round2(sgst),
      igst: round2(igst),
      amount: round2(baseAfterDisc + tax),
    };
  } else {
    // amount includes tax, extract taxable
    const taxable = baseAfterDisc / (1 + gstRate / 100);
    const tax = baseAfterDisc - taxable;
    const cgst = isIntraState ? tax / 2 : 0;
    const sgst = isIntraState ? tax / 2 : 0;
    const igst = isIntraState ? 0 : tax;

    return {
      taxable: round2(taxable),
      cgst: round2(cgst),
      sgst: round2(sgst),
      igst: round2(igst),
      amount: round2(baseAfterDisc),
    };
  }
}

function makeBlankLine(): Line {
  return {
    key: uid(),
    qty: 1,
    rate: 0,
    discMode: "PERCENT",
    discValue: 0,
    gstRate: 0,
    taxable: 0,
    cgst: 0,
    sgst: 0,
    igst: 0,
    amount: 0,
    expiry: null,
  };
}

