  );

  // Mock stock lots (replace via API, ideally filtered by warehouse)
  const stockLots: StockLot[] = useMemo(
    () => [
      { itemId: "2", batchNo: "MILK-A01", expiry: new Date(2026, 4, 1), availableQty: 20 },
      { itemId: "2", batchNo: "MILK-A02", expiry: new Date(2026, 5, 1), availableQty: 25 },
      { itemId: "2", batchNo: "MILK-A03", expiry: new Date(2026, 3, 1), availableQty: 5 },
    ],
    []
  );

  const lotsByItemId = useMemo(() => {
    const m = new Map<string, StockLot[]>();
    for (const lot of stockLots) {
      const arr = m.get(lot.itemId) ?? [];
      arr.push(lot);
      m.set(lot.itemId, arr);
    }
    // sort FEFO (earliest expiry first)
    for (const [k, v] of m.entries()) v.sort((a, b) => a.expiry.getTime() - b.expiry.getTime());
    return m;
  }, [stockLots]);

