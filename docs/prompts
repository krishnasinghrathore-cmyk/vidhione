                </div>
                <div className="text-right">
                  <div className="font-semibold">₹{it.prices[priceList].toFixed(2)}</div>
                </div>
              </div>
            )}
          />
        </div>
      </div>

      <DataTable
        ref={dtRef}
        value={rows}
        dataKey="key"
        editMode="cell"
        showGridlines
