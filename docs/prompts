import React, { useEffect, useMemo, useRef, useState } from "react";
import { DataTable } from "primereact/datatable";
import { Column } from "primereact/column";
import { AutoComplete, AutoCompleteCompleteEvent } from "primereact/autocomplete";
import { InputNumber, InputNumberValueChangeEvent } from "primereact/inputnumber";
import { Button } from "primereact/button";
import { OverlayPanel } from "primereact/overlaypanel";
import { Toast } from "primereact/toast";

type InvoiceMode = "B2C" | "B2B";

type ItemMaster = {
  id: string;
  name: string;
  sku?: string;
  barcode?: string;
  hsn: string;            // mandatory
  gstRate: number;        // e.g. 0, 5, 12, 18, 28
  unit: string;           // e.g. pcs, kg
  rate: number;           // default selling rate
  stock?: number;
};

type Line = {
  key: string;
  itemId?: string;
  itemName?: string;
  hsn?: string;
  unit?: string;
  qty: number;
  rate: number;
  disc: number;           // discount amount (simple)
  gstRate: number;
  amount: number;         // final line amount (incl/excl depending on setting)
  taxable: number;
  cgst: number;
  sgst: number;
  igst: number;
  hasError?: boolean;
  errorMsg?: string;
};

function uid() {
  return Math.random().toString(16).slice(2) + Date.now().toString(16);
}

const round2 = (n: number) => Math.round(n * 100) / 100;

function calcLine(opts: {
  qty: number;
  rate: number;
  disc: number;       // amount
  gstRate: number;    // percent
  isIntraState: boolean;
  taxInclusiveRate: boolean;
}) {
  const { qty, rate, disc, gstRate, isIntraState, taxInclusiveRate } = opts;

  const lineBase = Math.max(0, qty) * Math.max(0, rate);
  const baseAfterDisc = Math.max(0, lineBase - Math.max(0, disc));

  if (gstRate <= 0) {
    return {
      taxable: round2(baseAfterDisc),
      cgst: 0, sgst: 0, igst: 0,
      amount: round2(baseAfterDisc),
    };
  }

  if (!taxInclusiveRate) {
    const tax = (baseAfterDisc * gstRate) / 100;
    const cgst = isIntraState ? tax / 2 : 0;
    const sgst = isIntraState ? tax / 2 : 0;
    const igst = isIntraState ? 0 : tax;

    return {
      taxable: round2(baseAfterDisc),
      cgst: round2(cgst),
      sgst: round2(sgst),
      igst: round2(igst),
      amount: round2(baseAfterDisc + tax),
    };
  } else {
    // rate already includes tax => extract taxable
    const taxable = baseAfterDisc / (1 + gstRate / 100);
    const tax = baseAfterDisc - taxable;
    const cgst = isIntraState ? tax / 2 : 0;
    const sgst = isIntraState ? tax / 2 : 0;
    const igst = isIntraState ? 0 : tax;

    return {
      taxable: round2(taxable),
      cgst: round2(cgst),
      sgst: round2(sgst),
      igst: round2(igst),
      amount: round2(baseAfterDisc),
    };
  }
}

