          <Button label="B2B (GST)" size="small" outlined={invoiceMode !== "B2B"} onClick={() => setInvoiceMode("B2B")} />
        </div>

        <div className="flex align-items-center gap-2">
          <span className="font-semibold">Price List:</span>
          <Button label="Retail" size="small" outlined={priceList !== "retail"} onClick={() => setPriceList("retail")} />
          <Button label="Wholesale" size="small" outlined={priceList !== "wholesale"} onClick={() => setPriceList("wholesale")} />
        </div>

        <div className="flex align-items-center gap-2">
          <span className="font-semibold">Tax:</span>
          <Button
            label={isIntraState ? "Intra-state (CGST/SGST)" : "Inter-state (IGST)"}
            size="small"
            outlined
            onClick={() => setIsIntraState((v) => !v)}
          />
          <Button
            label={taxInclusiveRate ? "Rate: Inclusive" : "Rate: Exclusive"}
            size="small"
            outlined
            onClick={() => setTaxInclusiveRate((v) => !v)}
          />
        </div>

        <div className="flex align-items-center gap-2">
          <span className="font-semibold">Inventory:</span>
          <Button
            label={inventoryMode ? "Strict Validation: ON (F8)" : "Strict Validation: OFF (F8)"}
            size="small"
            outlined
            onClick={() => setInventoryMode((v) => !v)}
          />
        </div>

        {/* Item search */}
        <div className="flex align-items-center gap-2 ml-auto" style={{ minWidth: 430 }}>
          <span className="font-semibold">Item:</span>
          <AutoComplete
            ref={searchRef}
            value={query}
            suggestions={suggestions}
            completeMethod={onSearch}
            onChange={(e) => setQuery(e.value ?? "")}
            placeholder="Scan barcode / search item (F1)"
            field="name"
            dropdown
            onSelect={(e) => addItemToGrid(e.value as ItemMaster)}
