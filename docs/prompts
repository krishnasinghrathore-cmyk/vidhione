          removeRow(selected.key);
        }
      }
      if ((ev.ctrlKey || ev.metaKey) && (ev.key === "d" || ev.key === "D")) {
        if (selected?.itemId) {
          ev.preventDefault();
          duplicateRow(selected.key);
        }
      }
    };
