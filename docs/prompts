    }
  }

  // move to first editable cell of next row
  const nextRow = tr.nextElementSibling as HTMLTableRowElement | null;
  if (!nextRow) return;

  const nextTds = Array.from(nextRow.querySelectorAll("td"));
  const firstEditable = nextTds.find((c) => (c as HTMLElement).classList.contains("p-editable-column")) as HTMLElement | undefined;
  if (firstEditable) {
    const clickable = firstEditable.querySelector<HTMLElement>("[tabindex],input,button,textarea,.p-inputtext,.p-inputnumber-input");
    firstEditable.click();
    setTimeout(() => clickable?.focus?.(), 0);
  }
}

function isEnter(e: React.KeyboardEvent) {
  return e.key === "Enter" && !e.shiftKey && !e.altKey && !e.ctrlKey && !e.metaKey;
}

export default function PosAccountsInventoryGrid_Full() {
