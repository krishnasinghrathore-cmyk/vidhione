  // Row expansion: Batch/Expiry dropdown + Serials as Chips
  const rowExpansionTemplate = (r: Line) => {
    if (!r.itemId) return null;

    const showBatch = !!r.requiresBatch;
    const showExpiry = !!r.requiresExpiry;
    const showSerial = !!r.requiresSerial;

    if (!showBatch && !showExpiry && !showSerial) {
